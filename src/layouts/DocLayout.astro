---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.astro";
import Breadcrumb from "@aegis-initiative/design-system/components/Breadcrumb.astro";
import AegisWordmark from "@aegis-initiative/design-system/components/AegisWordmark.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The public home of the AEGIS Initiative — policy engagement, published analysis, and press presence",
} = Astro.props;

// Auto-generate breadcrumbs from URL path
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const segments = pathname.split('/').filter(Boolean);

const sectionLabels: Record<string, string> = {
  about: 'About',
  ecosystem: 'Ecosystem',
  research: 'Research & Policy',
  press: 'Press',
  contact: 'Contact',
  legal: 'Legal',
};

const breadcrumbItems: { label: string; href?: string }[] = [];
if (segments.length > 0 && sectionLabels[segments[0]]) {
  if (segments.length === 1) {
    // Section index — just show section name as current page
    breadcrumbItems.push({ label: sectionLabels[segments[0]] });
  } else {
    // Subpage — section links to its index, current page is plain text
    breadcrumbItems.push({ label: sectionLabels[segments[0]], href: `/${segments[0]}/` });
    breadcrumbItems.push({ label: title });
  }
}
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | AEGIS Initiative</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | AEGIS Initiative`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:site_name" content="AEGIS Initiative" />
    <meta property="og:image" content="https://aegis-initiative.com/OG_image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AEGIS Initiative`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://aegis-initiative.com/OG_image.png" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- AEGIS Ecosystem Navigation Bar -->
    <script src="/shared/aegis-nav.js" defer></script>
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site).toString()}
    />

    <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Prevent FOUC — apply theme before paint
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "AEGIS Initiative",
      "url": "https://aegis-initiative.com",
      "description": "The AEGIS Initiative exists to establish governance-first security as the foundational standard for autonomous AI systems.",
      "founder": {
        "@type": "Person",
        "name": "Kenneth Tannenbaum"
      },
      "foundingDate": "2026-01-26",
      "sameAs": [
        "https://github.com/aegis-initiative",
        "https://aegis-constitution.com",
        "https://aegis-docs.com"
      ]
    }
    </script>
  </head>
  <body>
    <Header />
    {breadcrumbItems.length > 0 && <Breadcrumb items={breadcrumbItems} homeLabel="AEGIS Initiative" />}
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
        <Footer />
        <div class="watermark">
          <AegisWordmark height={720} />
        </div>
      </main>
      <TableOfContents />
    </div>
  </body>
</html>

<style is:global>
  /* ============================================================
     AEGIS Design System — imported from shared package
     ============================================================ */
  @import '@aegis-initiative/design-system/css/fonts.css';
  @import '@aegis-initiative/design-system/css/tokens.css';
  @import '@aegis-initiative/design-system/css/reset.css';

  /* ============================================================
     Site-specific overrides
     ============================================================ */
  h1, h2, h3, h4, h5, h6 {
    scroll-margin-top: calc(5rem + var(--aegis-nav-height, 0px));
  }

  [id] {
    scroll-margin-top: calc(6.55rem + var(--aegis-nav-height, 0px));
  }

  /* ============================================================
     Breadcrumb alignment with sidebar
     ============================================================ */
  @media (min-width: 1024px) {
    .aegis-breadcrumb {
      padding-left: calc(280px + 2rem) !important;
    }
  }

  /* ToC links need higher specificity than global a reset */
  .toc-list a,
  .toc-dropdown-list a {
    text-decoration: none;
  }

  /* ============================================================
     Page Layout
     ============================================================ */
  .page-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem;
    max-width: 72rem;
  }

  /* ============================================================
     Watermark
     ============================================================ */
  .watermark {
    display: flex;
    justify-content: center;
    padding: 3rem 0 1rem;
    opacity: 0.08;
    filter: grayscale(100%);
    pointer-events: none;
    user-select: none;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (min-width: 1024px) {
    .main-content {
      padding: 2rem;
      margin-left: 280px;
    }
  }

  @media (min-width: 1367px) {
    .main-content {
      margin-right: 320px;
    }
  }
</style>
