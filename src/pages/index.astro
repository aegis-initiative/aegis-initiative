---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AegisWordmark from "@aegis-initiative/design-system/components/AegisWordmark.astro";
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AEGIS Initiative — Governance-First AI Security</title>
    <meta name="description" content="The AEGIS Initiative establishes governance-first security as the foundational standard for autonomous AI systems. Capability without constraint is not intelligence." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="AEGIS Initiative — Governance-First AI Security" />
    <meta property="og:description" content="Establishing governance-first security as the foundational standard for autonomous AI systems." />
    <meta property="og:url" content={new URL('/', Astro.site).toString()} />
    <meta property="og:site_name" content="AEGIS Initiative" />
    <meta property="og:image" content="https://aegis-initiative.com/OG_image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="AEGIS Initiative — Governance-First AI Security" />
    <meta name="twitter:description" content="Establishing governance-first security as the foundational standard for autonomous AI systems." />
    <meta name="twitter:image" content="https://aegis-initiative.com/OG_image.png" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={new URL('/', Astro.site).toString()} />

    <script src="/shared/aegis-nav.js" defer></script>

    <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "AEGIS Initiative",
      "url": "https://aegis-initiative.com",
      "description": "The AEGIS Initiative exists to establish governance-first security as the foundational standard for autonomous AI systems.",
      "founder": {
        "@type": "Person",
        "name": "Kenneth Tannenbaum"
      },
      "foundingDate": "2026-01-26",
      "sameAs": [
        "https://github.com/aegis-initiative",
        "https://aegis-constitution.com",
        "https://aegis-docs.com"
      ]
    }
    </script>
  </head>
  <body>
    <Header />

    <!-- ═══════════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <h1 class="hero-title">Governance-first security for autonomous AI</h1>
          <p class="hero-tagline">
            The AEGIS Initiative builds enforceable governance frameworks, open specifications,
            and runtime enforcement tools — so AI capability is always bounded by constitutional constraint.
          </p>
          <p class="hero-motto">Capability without constraint is not intelligence&trade;</p>
          <div class="hero-actions">
            <a href="/about/" class="btn btn-primary">
              Explore AEGIS
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
            <a href="https://github.com/aegis-initiative" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              GitHub
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
        <div class="hero-mark">
          <AegisWordmark width={360} />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         PRINCIPLES
         ═══════════════════════════════════════════════════════════ -->
    <section class="principles">
      <div class="section-inner">
        <div class="principles-grid">
          <div class="principle">
            <span class="principle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <span class="principle-text">Constraint before capability</span>
          </div>
          <div class="principle">
            <span class="principle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
            </span>
            <span class="principle-text">Governance before execution</span>
          </div>
          <div class="principle">
            <span class="principle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </span>
            <span class="principle-text">Transparency before trust</span>
          </div>
          <div class="principle">
            <span class="principle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </span>
            <span class="principle-text">Oversight before autonomy</span>
          </div>
          <div class="principle">
            <span class="principle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
            <span class="principle-text">Deny by default</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         SIGNAL — numbers that establish credibility
         ═══════════════════════════════════════════════════════════ -->
    <section class="signal">
      <div class="section-inner">
        <div class="signal-grid">
          <a href="/press/" class="signal-item">
            <span class="signal-number">4</span>
            <span class="signal-label">Papers submitted</span>
            <span class="signal-detail">IEEE, NIST, NCCoE</span>
          </a>
          <a href="https://aegis-docs.com/threat-matrix/" class="signal-item" target="_blank" rel="noopener noreferrer">
            <span class="signal-number">29</span>
            <span class="signal-label">Threat techniques</span>
            <span class="signal-detail">ATX-1 v2.1 taxonomy</span>
          </a>
          <a href="https://aegis-constitution.com/constitution/" class="signal-item" target="_blank" rel="noopener noreferrer">
            <span class="signal-number">11</span>
            <span class="signal-label">Constitutional articles</span>
            <span class="signal-detail">Governance charter</span>
          </a>
          <a href="https://github.com/aegis-initiative" class="signal-item" target="_blank" rel="noopener noreferrer">
            <span class="signal-number">7</span>
            <span class="signal-label">Public repositories</span>
            <span class="signal-detail">Specs, docs, tools</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         ECOSYSTEM — the AEGIS network of sites
         ═══════════════════════════════════════════════════════════ -->
    <section class="ecosystem">
      <div class="section-inner">
        <h2 class="section-title">The Ecosystem</h2>
        <p class="section-subtitle">AEGIS is a coordinated set of specifications, tools, and documentation — each with a dedicated site.</p>
        <div class="eco-grid">
          <a href="https://aegis-constitution.com" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>Constitution</h3>
            <p>The canonical governance charter — versioned, citeable, openly licensed. 11 articles defining the boundaries of AI autonomy.</p>
          </a>
          <a href="https://aegis-governance.com" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>Governance</h3>
            <p>Protocol specifications, threat taxonomy, RFCs, and the ATX-1 threat matrix for agentic AI systems.</p>
          </a>
          <a href="https://aegis-docs.com" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>Documentation</h3>
            <p>Developer guides, integration tutorials, and the technical reference for building with AEGIS.</p>
          </a>
          <a href="https://aegis-federation.com" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>Federation</h3>
            <p>Cross-domain machine discovery protocol for distributed AI governance across organizational boundaries.</p>
          </a>
          <a href="https://github.com/aegis-initiative/aegis-core" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>Core Runtime</h3>
            <p>The enforcement engine — a Python implementation of AGP-1 that evaluates governance policies at runtime.</p>
          </a>
          <a href="https://github.com/aegis-initiative/aegis-sdk" class="eco-card" target="_blank" rel="noopener noreferrer">
            <h3>SDKs</h3>
            <p>TypeScript and Python client libraries for integrating AEGIS governance into your applications.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         AUDIENCE — who is this for
         ═══════════════════════════════════════════════════════════ -->
    <section class="audience">
      <div class="section-inner">
        <h2 class="section-title">Who AEGIS is for</h2>
        <div class="audience-grid">
          <div class="audience-card">
            <h3>Policymakers &amp; Regulators</h3>
            <p>
              AEGIS provides a concrete, enforceable framework that translates AI governance principles
              into deterministic runtime constraints. Our work with NIST, IEEE, and NCCoE demonstrates
              how governance-first security can be standardized.
            </p>
            <a href="/research/" class="audience-link">
              Research &amp; policy
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="audience-card">
            <h3>Researchers &amp; Academics</h3>
            <p>
              All AEGIS specifications are openly published with DOIs, versioned for citation, and
              licensed under CC-BY-SA-4.0. The ATX-1 threat matrix and constitutional governance model
              are designed for academic rigor and reproducibility.
            </p>
            <a href="/press/" class="audience-link">
              Publications &amp; press
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="audience-card">
            <h3>Developers &amp; Engineers</h3>
            <p>
              Integrate governance enforcement into your AI systems with aegis-core, the Python runtime,
              and TypeScript/Python SDKs. Open source, well-tested, and designed for real-world deployment.
            </p>
            <a href="https://aegis-docs.com" class="audience-link" target="_blank" rel="noopener noreferrer">
              Developer docs
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         SITE NAV — what's on this site
         ═══════════════════════════════════════════════════════════ -->
    <section class="site-nav">
      <div class="section-inner">
        <h2 class="section-title">This Site</h2>
        <div class="nav-grid">
          <a href="/about/" class="nav-link">
            <span class="nav-link-title">About</span>
            <span class="nav-link-desc">What AEGIS is, how we work, and the three-layer architecture</span>
          </a>
          <a href="/ecosystem/" class="nav-link">
            <span class="nav-link-title">Ecosystem</span>
            <span class="nav-link-desc">Projects, architecture, and the public roadmap</span>
          </a>
          <a href="/research/" class="nav-link">
            <span class="nav-link-title">Research &amp; Policy</span>
            <span class="nav-link-desc">Published papers, NIST submissions, and policy engagement</span>
          </a>
          <a href="/press/" class="nav-link">
            <span class="nav-link-title">Press</span>
            <span class="nav-link-desc">Publications, software releases, milestones, and media kit</span>
          </a>
          <a href="/contact/" class="nav-link">
            <span class="nav-link-title">Contact</span>
            <span class="nav-link-desc">Press inquiries, policy engagement, or general questions</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         FOOTER
         ═══════════════════════════════════════════════════════════ -->
    <div class="splash-footer">
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  @import '@aegis-initiative/design-system/css/fonts.css';
  @import '@aegis-initiative/design-system/css/tokens.css';

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Hide sidebar menu button on splash page */
  .menu-btn {
    display: none !important;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: "Poppins", system-ui, sans-serif;
    font-weight: 300;
    background-color: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    line-height: 1.7;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-accent-high);
  }
</style>

<style>
  /* ── Layout scaffolding ────────────────────────────────────── */
  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    font-size: 2rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    max-width: 42rem;
    margin-bottom: 2rem;
  }

  /* ── Hero ───────────────────────────────────────────────────── */
  .hero {
    padding: 5rem 1.5rem 4rem;
  }

  .hero-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6rem;
  }

  .hero-text {
    flex: 1;
    max-width: 40rem;
  }

  .hero-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    font-size: 3.5rem;
    line-height: 1.12;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-motto {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .btn-primary {
    padding: 0.875rem 1.75rem;
    border-radius: 999px;
    font-size: 1.05rem;
    background-color: var(--color-accent);
    color: #ffffff;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-high);
    color: #ffffff;
  }

  .btn-secondary {
    padding: 0.875rem 1.25rem;
    border-radius: 999px;
    font-size: 1.05rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .btn-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero-mark {
    flex-shrink: 0;
    --color-brand-gray: #757575;
  }

  .hero-mark :global(.aegis-wordmark) {
    display: block;
  }

  /* ── Principles strip ──────────────────────────────────────── */
  .principles {
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    background-color: var(--color-bg-subtle);
    padding: 1.75rem 0;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    justify-items: start;
    max-width: 20rem;
    margin: 0 auto;
  }

  @media (min-width: 860px) {
    .principles-grid {
      grid-template-columns: repeat(6, auto);
      justify-content: center;
      justify-items: center;
      gap: 1rem 2.5rem;
      max-width: none;
    }

    /* Each item spans 2 of 6 columns → 3 per row */
    .principles-grid .principle {
      grid-column: span 2;
    }

    /* Center the last row: items 4 & 5 offset by 1 column each */
    .principles-grid .principle:nth-child(4) {
      grid-column: 2 / span 2;
    }
  }

  @media (min-width: 1100px) {
    .principles-grid {
      grid-template-columns: repeat(5, auto);
      gap: 0 3rem;
    }

    .principles-grid .principle {
      grid-column: auto;
    }

    .principles-grid .principle:nth-child(4) {
      grid-column: auto;
    }
  }

  .principle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .principle-icon {
    display: flex;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .principle-text {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* ── Signal / stats ────────────────────────────────────────── */
  .signal {
    padding: 4rem 0;
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .signal-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    text-decoration: none;
    padding: 1rem 0.5rem;
    border-radius: 6px;
    transition: background-color 0.15s;
  }

  .signal-item:hover {
    background-color: var(--color-bg-subtle);
  }

  .signal-number {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    font-size: 3rem;
    line-height: 1;
    color: var(--color-accent);
  }

  .signal-label {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-text);
    margin-top: 0.375rem;
  }

  .signal-detail {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* ── Ecosystem cards ───────────────────────────────────────── */
  .ecosystem {
    padding: 4rem 0;
    background-color: var(--color-accent-low);
    border-top: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .eco-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .eco-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    background-color: var(--color-bg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .eco-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .eco-card h3 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .eco-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Audience cards ────────────────────────────────────────── */
  .audience {
    padding: 4rem 0;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .audience-card {
    display: flex;
    flex-direction: column;
  }

  .audience-card h3 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .audience-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .audience-link {
