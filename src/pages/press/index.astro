---
import DocLayout from "../../layouts/DocLayout.astro";
---

<DocLayout title="Press" description="AEGIS Initiative press releases, published articles, and media resources.">
  <h1>Press</h1>

  <p>
    Press releases, published articles, and media resources from the AEGIS Initiative.
  </p>

  <hr />

  <section>
    <h2>Press Releases</h2>
    <p class="placeholder">
      Press releases will be published here with timestamps and permanent URLs
      as they are issued.
    </p>
  </section>

  <hr />

  <section>
    <h2>Published Articles</h2>
    <p class="placeholder">
      Articles published on LinkedIn and other platforms will be linked here
      with publication dates and summaries.
    </p>
  </section>

  <hr />

  <section>
    <h2>Media Kit</h2>
    <p>
      The AEGIS media kit provides approved logos, brand marks, and press-ready
      images for journalists and publications.
    </p>
    <ul>
      <li><strong>Approved logos and marks</strong> — available for download (coming soon)</li>
      <li><strong>Brand usage guidelines</strong> — how to use the AEGIS name and marks correctly</li>
      <li><strong>Press-ready images</strong> — high-resolution images for publication</li>
    </ul>
    <p>
      For immediate access to brand assets, contact
      <a href="mailto:press@aegis-initiative.com">press@aegis-initiative.com</a>.
    </p>
  </section>

  <hr />

  <section>
    <h2>Press Contact</h2>
    <p>
      For press inquiries, interview requests, or media access:
    </p>
    <p>
      <strong>Email:</strong> <a href="mailto:press@aegis-initiative.com">press@aegis-initiative.com</a>
    </p>
  </section>
</DocLayout>

<style>
  .placeholder {
    font-style: italic;
    color: var(--color-text-muted);
    padding: 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    background-color: var(--color-bg-subtle);
  }
</style>
