---
/**
 * Site-specific Sidebar wrapper.
 * Declares the aegis-initiative nav structure and delegates rendering
 * to the shared design-system Sidebar component.
 */
import SharedSidebar from '@aegis-initiative/design-system/components/Sidebar.astro';

interface NavItem {
  label: string;
  slug: string;
  items?: NavItem[];
}

const nav: NavItem[] = [
  { label: 'Home', slug: '' },
  {
    label: 'About',
    slug: 'about',
    items: [
      { label: 'Overview', slug: 'about' },
      { label: 'Mission & Vision', slug: 'about/mission' },
      { label: 'Team & Leadership', slug: 'about/team' },
      { label: 'How We Work', slug: 'about/how-we-work' },
      { label: 'Funding & Support', slug: 'about/funding' },
    ],
  },
  {
    label: 'Ecosystem',
    slug: 'ecosystem',
    items: [
      { label: 'Overview', slug: 'ecosystem' },
      { label: 'Projects', slug: 'ecosystem/projects' },
      { label: 'Roadmap', slug: 'ecosystem/roadmap' },
      { label: 'Timeline', slug: 'ecosystem/timeline' },
      { label: 'Design System', slug: 'ecosystem/design-system' },
    ],
  },
  {
    label: 'Research & Policy',
    slug: 'research',
    items: [
      { label: 'Overview', slug: 'research' },
      { label: 'Published Papers', slug: 'research/papers' },
      { label: 'Standards Engagement', slug: 'research/standards' },
      { label: 'Policy Positions', slug: 'research/policy' },
    ],
  },
  {
    label: 'Press',
    slug: 'press',
    items: [
      { label: 'Overview', slug: 'press' },
      { label: 'Publications & Releases', slug: 'press/publications' },
      { label: 'Milestones', slug: 'press/milestones' },
      { label: 'Media Kit', slug: 'press/media-kit' },
    ],
  },
  { label: 'Contact', slug: 'contact' },
];

const legalNav: NavItem[] = [
  { label: 'Terms of Use', slug: 'legal/terms' },
  { label: 'Privacy Policy', slug: 'legal/privacy' },
  { label: 'Acceptable Use', slug: 'legal/acceptable-use' },
  { label: 'Accessibility', slug: 'legal/accessibility' },
  { label: 'Cookie Policy', slug: 'legal/cookies' },
  { label: 'Disclaimer', slug: 'legal/disclaimer' },
  { label: 'DMCA & Takedown', slug: 'legal/dmca' },
  { label: 'Impressum', slug: 'legal/impressum' },
